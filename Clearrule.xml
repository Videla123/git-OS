'*********************************************************************
' Author      :  Kiran Videla
' Created On  :  22-04-2026
' Purpose:
' Admin rule to clear data for a configurable POV defined
' in dbfForecastData. The rule leverages Data Buffer logic for
' high-performance clearing and is executed via the Custom Clear
' Data Management step for the selected Entity, Scenario, and Time.
'*********************************************************************

 
Namespace OneStream.BusinessRule.Finance.FLS_Cleardata_Buffer
	Public Class MainClass
		Public Function Main(ByVal si As SessionInfo, ByVal globals As BRGlobals, ByVal api As FinanceRulesApi, ByVal args As FinanceRulesArgs) As Object
			Try
				Dim dbfForecastData As DataBuffer = api.Data.GetDataBufferUsingFormula("V#Periodic:A#All:F#All:O#All:I#All:U1#All:U2#All:U3#All:U4#All:U5#All:U6#All:U7#All:U8#All",,False)
				api.Data.FormulaVariables.SetDataBufferVariable("dbfForecastData", dbfForecastData, False)
				
				
				Dim destination As ExpressionDestinationInfo = api.Data.GetExpressionDestinationInfo("")
				
				If (Not dbfForecastData Is Nothing ) Then 
					Dim resultBufferToClear As New DataBuffer()
					For Each sourceCell As DataBufferCell In dbfForecastData.DataBufferCells.Values
						Dim resultCell As New DataBufferCell(sourceCell)
						resultCell.CellAmount = 0
						resultCell.CellStatus = DataCellStatus.CreateDataCellStatus(True, False)
						resultBufferToClear.SetCell(si, resultCell)
					Next
					
					api.Data.SetDataBuffer(resultBufferToClear,destination)
				End If
				Return Nothing
			Catch ex As Exception
				Throw ErrorHandler.LogWrite(si, New XFException(si, ex))
			End Try
		End Function
	End Class
End Namespace